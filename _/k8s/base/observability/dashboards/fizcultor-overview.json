{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "uid": "fizcultor-overview",
  "title": "fizcultor — overview",
  "tags": ["fizcultor", "production"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "service",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(service)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {"selected": false, "text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Services up",
      "datasource": "Prometheus",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {"expr": "count(count by (service) (up{job=\"fizcultor-services\"} == 1))", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "green", "value": 7}
            ]
          },
          "unit": "short",
          "max": 7
        }
      },
      "options": {"colorMode": "background", "graphMode": "none", "textMode": "value_and_name"}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "gRPC requests per second (per service)",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "sum by (service) (rate({__name__=~\"(auth|bmstu|filter|teachers|notifier|gateway)_grpc_requests_total\", service=~\"$service\"}[1m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "gRPC error rate (per service, code != OK)",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
      "targets": [
        {
          "expr": "sum by (service) (rate({__name__=~\"(auth|bmstu|filter|teachers|notifier|gateway)_grpc_requests_total\", code!=\"OK\", service=~\"$service\"}[5m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "gRPC latency p95 (seconds, per service)",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, service) (rate({__name__=~\"(auth|bmstu|filter|teachers|notifier|gateway)_grpc_request_duration_seconds_bucket\", service=~\"$service\"}[5m])))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "gRPC latency p99",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, service) (rate({__name__=~\"(auth|bmstu|filter|teachers|notifier|gateway)_grpc_request_duration_seconds_bucket\", service=~\"$service\"}[5m])))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Gateway HTTP requests rate by route",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "sum by (route) (rate(gateway_http_requests_total[1m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Gateway HTTP errors (status>=500)",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "sum by (route, status) (rate(gateway_http_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "{{route}} ({{status}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Gateway SSE connections",
      "datasource": "Prometheus",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 24},
      "targets": [
        {"expr": "gateway_sse_connections", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"colorMode": "value", "graphMode": "area"}
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Poller — cycle duration",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 9, "x": 6, "y": 24},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(poller_cycle_duration_seconds_bucket[10m])))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(poller_cycle_duration_seconds_bucket[10m])))",
          "legendFormat": "p50",
          "refId": "B"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Poller — users polled by result",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 9, "x": 15, "y": 24},
      "targets": [
        {
          "expr": "sum by (result) (rate(poller_users_polled_total[5m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "BMSTU login attempts (auth-svc + bmstu-svc)",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
      "targets": [
        {
          "expr": "sum by (result) (rate(bmstu_login_attempts_total[5m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Notifier — messages sent by channel",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
      "targets": [
        {
          "expr": "sum by (channel, result) (rate(notifier_sent_total[5m]))",
          "legendFormat": "{{channel}}/{{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Go runtime — memory (heap inuse)",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 40},
      "targets": [
        {
          "expr": "go_memstats_heap_inuse_bytes",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Go runtime — goroutines",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 40},
      "targets": [
        {
          "expr": "go_goroutines",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "DB query latency p95 (per service / query)",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 48},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, service, query) (rate({__name__=~\".+_db_query_duration_seconds_bucket\", service=~\"$service\"}[5m])))",
          "legendFormat": "{{service}}/{{query}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    }
  ]
}

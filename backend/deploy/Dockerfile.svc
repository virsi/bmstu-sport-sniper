# syntax=docker/dockerfile:1.7
#
# Multi-stage Dockerfile, параметризованный через ARG SERVICE.
#
# Build:
#   docker build -f backend/deploy/Dockerfile.svc \
#                --build-arg SERVICE=auth-svc \
#                -t fizcultor/auth-svc:dev backend
#
# Контекст сборки — backend/.

# ---------- builder ----------
FROM golang:1.23-alpine AS builder

ARG SERVICE
ARG VERSION=dev
ARG COMMIT=unknown

RUN apk add --no-cache git ca-certificates tzdata

WORKDIR /src

# Сначала копируем workspace + ВСЕ go.mod (только stubs).
# go.work ссылается на все модули — без хотя бы пустых go.mod
# go workspace падает при resolution. Подробности: ../CLAUDE.md.
COPY go.work go.work
COPY pkg/go.mod pkg/go.sum pkg/
COPY gen/go.mod gen/go.sum gen/
COPY tests/testhelpers/go.mod tests/testhelpers/go.sum tests/testhelpers/
COPY services/auth-svc/go.mod services/auth-svc/go.sum services/auth-svc/
COPY services/bmstu-svc/go.mod services/bmstu-svc/go.sum services/bmstu-svc/
COPY services/filter-svc/go.mod services/filter-svc/go.sum services/filter-svc/
COPY services/gateway-svc/go.mod services/gateway-svc/go.sum services/gateway-svc/
COPY services/notifier-svc/go.mod services/notifier-svc/go.sum services/notifier-svc/
COPY services/poller-svc/go.mod services/poller-svc/go.sum services/poller-svc/
COPY services/teachers-svc/go.mod services/teachers-svc/go.sum services/teachers-svc/

# Скачиваем модули нужного сервиса (workspace replace pointers).
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    cd services/${SERVICE} && go mod download

# Копируем исходники нужного сервиса + всё на что он ссылается через replace.
COPY pkg/ pkg/
COPY gen/ gen/
COPY services/${SERVICE}/ services/${SERVICE}/

# Сборка статического бинарника.
ENV CGO_ENABLED=0 GOOS=linux GOFLAGS="-trimpath"
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    cd services/${SERVICE} && \
    go build -ldflags="-s -w -X main.version=${VERSION} -X main.commit=${COMMIT}" \
             -o /out/server ./cmd/server

# ---------- runtime ----------
FROM gcr.io/distroless/static:nonroot

COPY --from=builder /out/server /server
COPY --from=builder /usr/share/zoneinfo /usr/share/zoneinfo
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/ca-certificates.crt

USER nonroot:nonroot
EXPOSE 8080 9090

ENTRYPOINT ["/server"]

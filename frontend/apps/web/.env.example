# Dev defaults — реальные значения идут через .env.local или docker-compose.
# В dev base относительный — идёт через vite-proxy на :8080 (см. vite.config.ts).

# Базовый URL REST gateway-svc. В prod — абсолютный, в dev — `/api` через proxy.
VITE_API_BASE_URL=/api

# SSE endpoint. По умолчанию /api/stream (тоже через proxy в dev).
VITE_SSE_URL=/api/stream

# Username Telegram-бота (без @). Используется в подписях UI.
# Реальный deeplink приходит из backend в LinkTelegramInit response.
VITE_BOT_USERNAME=FizcultorBot
